{
  "family": "memos_task_family",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::${aws_account}:role/memos_role_1",
  "containerDefinitions": [
    {
      "name": "memos",
      "image": "${ecr_repo}:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8081 }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "memos_cloudwatch_log_group",
          "awslogs-region": "${region}",
          "awslogs-stream-prefix": "memos"
        }
      }
    }
  ]
}